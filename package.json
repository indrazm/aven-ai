{
	"name": "aven-ai",
	"version": "0.1.0",
	"description": "A full-screen Anvia coding agent terminal with OpenAI, Anthropic, and PTY tools.",
	"type": "module",
	"private": true,
	"bin": {
		"aven-ai": "dist/index.js"
	},
	"engines": {
		"node": ">=22"
	},
	"packageManager": "pnpm@11.9.0",
	"scripts": {
		"dev": "tsx src/index.ts",
		"clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
		"build": "pnpm clean && tsc -p tsconfig.build.json && node scripts/mark-cli-executable.mjs",
		"start": "node dist/index.js",
		"install:local": "pnpm build && node scripts/install-local.mjs",
		"uninstall:local": "node scripts/install-local.mjs --uninstall",
		"prepare": "node scripts/install-git-hooks.mjs",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"typecheck": "tsc --noEmit",
		"lint": "eslint .",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest",
		"check": "pnpm format:check && pnpm typecheck && pnpm lint && pnpm test:coverage && pnpm build"
	},
	"dependencies": {
		"@anvia/anthropic": "^0.3.14",
		"@anvia/core": "^0.13.0",
		"@anvia/memory-sqlite": "^0.2.2",
		"@anvia/openai": "^0.3.16",
		"@inkjs/ui": "^2.0.0",
		"diff": "^9.0.0",
		"fuse.js": "^7.4.2",
		"ink": "^7.1.0",
		"marked": "^18.0.6",
		"node-pty": "^1.1.0",
		"react": "^19.2.0",
		"smol-toml": "^1.7.0",
		"string-width": "^8.2.2",
		"strip-ansi": "^7.1.2",
		"zod": "^4.4.3",
		"zustand": "^5.0.14"
	},
	"devDependencies": {
		"@babel/core": "^8.0.1",
		"@babel/eslint-parser": "^8.0.1",
		"@babel/preset-typescript": "^8.0.1",
		"@eslint/js": "^10.0.1",
		"@types/node": "^24.0.0",
		"@types/react": "^19.2.0",
		"@vitest/coverage-v8": "4.1.10",
		"eslint": "^10.7.0",
		"eslint-plugin-react-hooks": "^7.1.1",
		"ink-testing-library": "^4.0.0",
		"prettier": "^3.9.5",
		"tsx": "^4.23.0",
		"typescript": "^7.0.2",
		"vitest": "^4.1.10"
	}
}
